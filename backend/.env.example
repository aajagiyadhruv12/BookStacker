## Firebase Configuration - for local development
# Generate this from your Firebase project settings: Project settings > Service accounts > Generate new private key
# Important: DO NOT commit the actual serviceAccountKey.json file to git.
FIREBASE_SERVICE_ACCOUNT_PATH="./serviceAccountKey.json"

## Firebase Configuration - for production (Render, Vercel, etc.)
# Copy the entire contents of your serviceAccountKey.json file and paste it here as a single line.
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Your Firebase project's storage bucket URL
FIREBASE_STORAGE_BUCKET="bookstacker0.appspot.com"

## Flask Configuration
FLASK_ENV="development"
DEBUG=True
SECRET_KEY="your-very-secret-key"
